<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@color/purple_700"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz Ergebnis"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <!-- Score Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="85%"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_700" />

                    <TextView
                        android:id="@+id/tvPassFail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎉 Bestanden!"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvCorrectCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8 von 10 richtig"
                        android:textSize="14sp"
                        android:textColor="@android:color/darker_gray"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvTimeSpent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zeit: 5:30"
                        android:textSize="12sp"
                        android:textColor="@android:color/darker_gray"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Encouragement -->
            <TextView
                android:id="@+id/tvEncouragement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gut gemacht! Du bist auf dem richtigen Weg!"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:textAlignment="center"
                android:layout_marginTop="12dp" />

            <!-- Progress Bar -->
            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30/100 gelöst"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />

            <ProgressBar
                android:id="@+id/progressQuiz"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:max="100"
                android:progress="30" />
        </LinearLayout>

        <!-- Completion Banner (hidden by default) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardComplete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/green_100"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎉 Alle Fragen abgeschlossen!"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_700" />

                <TextView
                    android:id="@+id/tvCompleteMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Du hast alle 100 Fragen fur dieses Thema gelost!"
                    android:textSize="14sp"
                    android:textColor="@color/green_600"
                    android:textAlignment="center"
                    android:layout_marginTop="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetProgress"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄 Neu beginnen (alle 100 zurucksetzen)"
                    android:textSize="13sp"
                    android:textColor="@color/green_700"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Loop Message (hidden by default) -->
        <TextView
            android:id="@+id/tvLoopMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:layout_marginHorizontal="16dp"
            android:background="@color/orange_100"
            android:textColor="@color/orange_800"
            android:textSize="13sp"
            android:visibility="gone"
            android:text="🔄 Loop restart message here" />

        <!-- Results List -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Detaillierte Ergebnisse"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:padding="8dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Next Quiz Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📝 Nächstes Quiz (10 neue Fragen)"
                android:textSize="16sp"
                android:backgroundTint="@color/purple_700" />

            <!-- Retry Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetry"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔄 Erneut versuchen (gleiche Fragen)"
                android:textSize="15sp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackToSubjects"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="← Themen"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShare"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📤 Teilen"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
