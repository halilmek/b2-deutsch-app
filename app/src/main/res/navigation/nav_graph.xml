<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Auth Flow -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.b2deutsch.app.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_signUp"
            app:destination="@id/signUpFragment"
            app:popUpTo="@id/loginFragment" />

        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.b2deutsch.app.ui.auth.SignUpFragment"
        android:label="Sign Up"
        tools:layout="@layout/fragment_sign_up">

        <action
            android:id="@+id/action_signUp_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Main Flow -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.b2deutsch.app.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_subjectList"
            app:destination="@id/subjectListFragment" />

        <action
            android:id="@+id/action_home_to_exams"
            app:destination="@id/examsFragment" />

        <action
            android:id="@+id/action_home_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Subjects — Themen & Fächer -->
    <fragment
        android:id="@+id/subjectListFragment"
        android:name="com.b2deutsch.app.ui.subject.SubjectListFragment"
        android:label="Themen"
        tools:layout="@layout/fragment_subject_list">

        <argument
            android:name="level"
            app:argType="string"
            android:defaultValue="B2" />

        <action
            android:id="@+id/action_subjectList_to_subjectDetail"
            app:destination="@id/subjectDetailFragment">
            <argument
                android:name="subjectId"
                app:argType="string" />
            <argument
                android:name="subjectName"
                app:argType="string" />
        </action>
        <action
            android:id="@+id/action_subjectList_to_quizActive"
            app:destination="@id/quizActiveFragment">
            <argument
                android:name="quizId"
                app:argType="string" />
            <argument
                android:name="subjectId"
                app:argType="string" />
        </action>

    </fragment>

    <fragment
        android:id="@+id/subjectDetailFragment"
        android:name="com.b2deutsch.app.ui.subject.SubjectDetailFragment"
        android:label="Thema"
        tools:layout="@layout/fragment_subject_detail">

        <argument
            android:name="subjectId"
            app:argType="string" />
        <argument
            android:name="subjectName"
            app:argType="string" />

        <action
            android:id="@+id/action_subjectDetail_to_quizActive"
            app:destination="@id/quizActiveFragment">
            <argument
                android:name="quizId"
                app:argType="string" />
            <argument
                android:name="subjectId"
                app:argType="string"
                android:defaultValue="" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/subjectResultFragment"
        android:name="com.b2deutsch.app.ui.subject.SubjectResultFragment"
        android:label="Ergebnis"
        tools:layout="@layout/fragment_subject_result">

        <action
            android:id="@+id/action_result_to_subjectList"
            app:destination="@id/subjectListFragment"
            app:popUpTo="@id/subjectListFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Exams -->
    <fragment
        android:id="@+id/examsFragment"
        android:name="com.b2deutsch.app.ui.exams.ExamsFragment"
        android:label="Exams"
        tools:layout="@layout/fragment_exams">

        <argument
            android:name="level"
            app:argType="string"
            android:defaultValue="C1" />

        <action
            android:id="@+id/action_exams_to_examActive"
            app:destination="@id/examActiveFragment">
            <argument
                android:name="examId"
                app:argType="string" />
            <argument
                android:name="level"
                app:argType="string" />
            <argument
                android:name="examTitle"
                app:argType="string" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/examActiveFragment"
        android:name="com.b2deutsch.app.ui.exams.ExamActiveFragment"
        android:label="Exam"
        tools:layout="@layout/fragment_exam_active">

        <argument
            android:name="examId"
            app:argType="string" />
        <argument
            android:name="level"
            app:argType="string" />
        <argument
            android:name="examTitle"
            app:argType="string" />

        <action
            android:id="@+id/action_examActive_to_examResult"
            app:destination="@id/examResultFragment">
            <argument
                android:name="examId"
                app:argType="string" />
            <argument
                android:name="level"
                app:argType="string" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/examResultFragment"
        android:name="com.b2deutsch.app.ui.exams.ExamResultFragment"
        android:label="Exam Results"
        tools:layout="@layout/fragment_exam_result">

        <argument
            android:name="examId"
            app:argType="string" />
        <argument
            android:name="level"
            app:argType="string" />
    </fragment>

    <!-- Legacy Quiz Flow (kept for backward compatibility) -->
    <fragment
        android:id="@+id/quizzesFragment"
        android:name="com.b2deutsch.app.ui.quiz.QuizzesFragment"
        android:label="Quizzes"
        tools:layout="@layout/fragment_quizzes">

        <action
            android:id="@+id/action_quizzes_to_quizActive"
            app:destination="@id/quizActiveFragment">
            <argument
                android:name="quizId"
                app:argType="string" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/quizActiveFragment"
        android:name="com.b2deutsch.app.ui.quiz.QuizActiveFragment"
        android:label="Quiz"
        tools:layout="@layout/fragment_quiz_active">

        <argument
            android:name="quizId"
            app:argType="string" />

        <action
            android:id="@+id/action_quizActive_to_result"
            app:destination="@id/quizResultFragment">
            <argument
                android:name="quizId"
                app:argType="string" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/quizResultFragment"
        android:name="com.b2deutsch.app.ui.quiz.QuizResultFragment"
        android:label="Results"
        tools:layout="@layout/fragment_quiz_result">

        <argument
            android:name="quizId"
            app:argType="string" />

        <argument
            android:name="subjectId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />

        <argument
            android:name="score"
            app:argType="integer"
            android:defaultValue="0" />

        <argument
            android:name="passed"
            app:argType="boolean"
            android:defaultValue="false" />

        <argument
            android:name="correct"
            app:argType="integer"
            android:defaultValue="0" />

        <argument
            android:name="total"
            app:argType="integer"
            android:defaultValue="0" />

        <action
            android:id="@+id/action_result_to_nextQuiz"
            app:destination="@id/quizActiveFragment"
            app:popUpTo="@id/quizActiveFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_result_to_subjectList"
            app:destination="@id/subjectListFragment"
            app:popUpTo="@id/subjectListFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Legacy Lessons (kept for backward compatibility) -->
    <fragment
        android:id="@+id/lessonsFragment"
        android:name="com.b2deutsch.app.ui.lessons.LessonsFragment"
        android:label="Lessons"
        tools:layout="@layout/fragment_lessons">

        <action
            android:id="@+id/action_lessons_to_detail"
            app:destination="@id/lessonDetailFragment">
            <argument
                android:name="lessonId"
                app:argType="string" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/lessonDetailFragment"
        android:name="com.b2deutsch.app.ui.lessons.LessonDetailFragment"
        android:label="Lesson"
        tools:layout="@layout/fragment_lesson_detail">

        <argument
            android:name="lessonId"
            app:argType="string" />
    </fragment>

    <!-- Legacy Vocabulary -->
    <fragment
        android:id="@+id/vocabularyFragment"
        android:name="com.b2deutsch.app.ui.vocabulary.VocabularyFragment"
        android:label="Vocabulary"
        tools:layout="@layout/fragment_vocabulary" />

    <!-- Legacy Writing -->
    <fragment
        android:id="@+id/writingFragment"
        android:name="com.b2deutsch.app.ui.writing.WritingFragment"
        android:label="Writing"
        tools:layout="@layout/fragment_writing" />

    <!-- Legacy Speaking -->
    <fragment
        android:id="@+id/speakingFragment"
        android:name="com.b2deutsch.app.ui.speaking.SpeakingFragment"
        android:label="Speaking"
        tools:layout="@layout/fragment_speaking" />

</navigation>
